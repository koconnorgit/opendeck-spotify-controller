{
  "Name": "Spotify Controller",
  "Author": "koconnorgit",
  "Version": "0.1.0",
  "CodePaths": {
    "x86_64-unknown-linux-gnu": "oa-spotify-controller-x86_64-unknown-linux-gnu",
    "aarch64-unknown-linux-gnu": "oa-spotify-controller-aarch64-unknown-linux-gnu"
  },
  "CodePathLin": "oa-spotify-controller-x86_64-unknown-linux-gnu",
  "OS": [
    {
      "Platform": "linux"
    }
  ],
  "Category": "Spotify Controller",
  "Description": "Control Spotify playback, volume, and display album art on your Stream Deck.",
  "Icon": "img/icon",
  "Actions": [
    {
      "Icon": "img/play-pause",
      "Name": "Play / Pause",
      "UUID": "com.opendeck.spotify-controller.play-pause",
      "Tooltip": "Toggle Spotify playback",
      "Controllers": ["Keypad"],
      "States": [{}]
    },
    {
      "Icon": "img/next",
      "Name": "Next Track",
      "UUID": "com.opendeck.spotify-controller.next-track",
      "Tooltip": "Skip to the next track",
      "Controllers": ["Keypad"],
      "States": [{}]
    },
    {
      "Icon": "img/prev",
      "Name": "Previous Track",
      "UUID": "com.opendeck.spotify-controller.prev-track",
      "Tooltip": "Go to the previous track",
      "Controllers": ["Keypad"],
      "States": [{}]
    },
    {
      "Icon": "img/dial",
      "Name": "Spotify Dial",
      "UUID": "com.opendeck.spotify-controller.dial",
      "Tooltip": "Rotate for volume, press for play/pause. LCD shows album art.",
      "Controllers": ["Encoder"],
      "Encoder": {
        "layout": "$B1",
        "TriggerDescription": {
          "Rotate": "Adjust volume",
          "Push": "Play / Pause",
          "Touch": "Play / Pause",
          "LongTouch": ""
        }
      },
      "States": [{}]
    },
    {
      "Icon": "img/icon",
      "Name": "Album Art 1x1",
      "UUID": "com.opendeck.spotify-controller.art-1x1",
      "Tooltip": "Display full album art on a single button.",
      "Controllers": ["Keypad"],
      "States": [{}]
    },
    {
      "Icon": "img/icon",
      "Name": "Album Art 2x2",
      "UUID": "com.opendeck.spotify-controller.art-2x2",
      "Tooltip": "Album art spread across 4 buttons. Place 4 copies in a 2x2 block.",
      "Controllers": ["Keypad"],
      "States": [{}]
    },
    {
      "Icon": "img/icon",
      "Name": "Album Art 3x3",
      "UUID": "com.opendeck.spotify-controller.art-3x3",
      "Tooltip": "Album art spread across 9 buttons. Place 9 copies in a 3x3 block.",
      "Controllers": ["Keypad"],
      "States": [{}]
    },
    {
      "Icon": "img/icon",
      "Name": "Album Art 4x4",
      "UUID": "com.opendeck.spotify-controller.art-4x4",
      "Tooltip": "Album art spread across 16 buttons. Place 16 copies in a 4x4 block.",
      "Controllers": ["Keypad"],
      "States": [{}]
    }
  ]
}
